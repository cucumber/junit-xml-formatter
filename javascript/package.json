{
  "name": "@cucumber/junit-xml-formatter",
  "version": "0.14.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cucumber/junit-xml-formatter.git"
  },
  "author": "David Goss",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "fix": "biome check --fix --error-on-warnings",
    "lint": "biome check --error-on-warnings",
    "postbuild": "node -e \"require('.')\"",
    "test": "mocha \"src/**/*.spec.ts\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@cucumber/query": "^16.0.0",
    "@teppeis/multimaps": "^3.0.0",
    "luxon": "^3.5.0",
    "xmlbuilder": "^15.1.1"
  },
  "peerDependencies": {
    "@cucumber/messages": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cucumber/biome-config": "github:cucumber/biome-config#v0.2.1",
    "@cucumber/message-streams": "^5.0.0",
    "@cucumber/messages": "33.0.2",
    "@tsconfig/recommended": "^1.0.8",
    "@types/chai": "^5.0.0",
    "@types/chai-almost": "^1.0.3",
    "@types/chai-xml": "^0.3.6",
    "@types/luxon": "^3.4.2",
    "@types/mocha": "^10.0.6",
    "@types/node": "^22",
    "chai": "^6.0.0",
    "chai-almost": "^1.0.1",
    "chai-xml": "^0.4.1",
    "globby": "^16.0.0",
    "mocha": "^11.0.0",
    "ts-node": "^10.9.1",
    "typescript": "6.0.3"
  }
}
